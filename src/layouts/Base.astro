---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Horizons Nexus — San Francisco, June 19–21',
  description = 'Horizons Nexus is coming to San Francisco June 19th–21st. Sign up now.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
