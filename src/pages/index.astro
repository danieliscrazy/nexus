---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import bgTexture from '../assets/figma/bg-texture.png';
import leftNexusSketch from '../assets/figma/left-nexus-sketch.png';
import fullNexusSketch from '../assets/figma/full-nexus-sketch.png';
import spiral from '../assets/figma/spiral.png';
import orb from '../assets/figma/orb.png';
import cardBorder from '../assets/figma/card-border.png';
import cardBorderBack from '../assets/figma/card-border-back.png';
import bgTextureChalk from '../assets/figma/bg-texture-chalk.png';
import bordTl from '../assets/figma/bord/tl.png';
import bordTop from '../assets/figma/bord/top.png';
import bordTr from '../assets/figma/bord/tr.png';
import bordLeft from '../assets/figma/bord/left.png';
import bordCenter from '../assets/figma/bord/center.png';
import bordRight from '../assets/figma/bord/right.png';
import bordBl from '../assets/figma/bord/bl.png';
import bordBottom from '../assets/figma/bord/bottom.png';
import bordBr from '../assets/figma/bord/br.png';
import nexusLogo from '../assets/figma/nexus.svg';
import infoStrip from '../assets/figma/info-strip.png';
import infoPhoto from '../assets/figma/info-photo.png';

const infoBg = `url('${bgTexture.src}')`;
const faqBg = `url('${bgTextureChalk.src}')`;
---

<Base>
  <div class="scroll-shell">
    <main class="hero">
      <div class="bg" aria-hidden="true">
        <Image
          class="bg__base"
          src={bgTexture}
          alt=""
          widths={[800, 1403, 2200]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
        />
        <Image
          class="bg__strand bg__strand--left"
          src={leftNexusSketch}
          alt=""
          widths={[400, 612, 1200]}
          sizes="(max-width: 800px) 70vh, 612px"
          loading="eager"
        />
        <Image
          class="bg__strand bg__strand--right"
          src={fullNexusSketch}
          alt=""
          widths={[400, 611, 1200]}
          sizes="(max-width: 800px) 70vh, 611px"
          loading="eager"
        />
        <Image
          class="bg__doodles"
          src={spiral}
          alt=""
          widths={[800, 1534, 2400]}
          sizes="110vw"
          loading="eager"
        />
        <div class="bg__blob">
          <Image
            class="bg__blob-img"
            src={orb}
            alt=""
            widths={[800, 1600, 2400]}
            sizes="(max-width: 800px) 180vw, 140vw"
            loading="eager"
          />
        </div>
      </div>

      <div class="stage4" aria-hidden="true">
        <Image
          class="stage4-bg"
          src={bgTextureChalk}
          alt=""
          widths={[800, 1403, 2200]}
          sizes="100vw"
          loading="eager"
        />
        <div class="stage4-frame">
          <div class="bord-frame">
            <div class="bord-slice bord-slice--tl"><Image src={bordTl} alt="" widths={[60, 120]} sizes="5vw" loading="eager" /></div>
            <div class="bord-slice bord-slice--top"><Image src={bordTop} alt="" widths={[300, 600, 900]} sizes="35vw" loading="eager" /></div>
            <div class="bord-slice bord-slice--tr"><Image src={bordTr} alt="" widths={[60, 120]} sizes="5vw" loading="eager" /></div>
            <div class="bord-slice bord-slice--left"><Image src={bordLeft} alt="" widths={[60, 120]} sizes="5vw" loading="eager" /></div>
            <div class="bord-slice bord-slice--center"><Image src={bordCenter} alt="" widths={[300, 600, 900]} sizes="35vw" loading="eager" /></div>
            <div class="bord-slice bord-slice--right"><Image src={bordRight} alt="" widths={[60, 120]} sizes="5vw" loading="eager" /></div>
            <div class="bord-slice bord-slice--bl"><Image src={bordBl} alt="" widths={[60, 120]} sizes="5vw" loading="eager" /></div>
            <div class="bord-slice bord-slice--bottom"><Image src={bordBottom} alt="" widths={[300, 600, 900]} sizes="35vw" loading="eager" /></div>
            <div class="bord-slice bord-slice--br"><Image src={bordBr} alt="" widths={[60, 120]} sizes="5vw" loading="eager" /></div>
            <p class="bord-text">Here&rsquo;s how it works</p>
          </div>
          <div class="steps-card steps-card--1"><img class="steps-img" src="/steps.png" alt="" /></div>
          <div class="steps-card steps-card--2"><img class="steps-img" src="/steps.png" alt="" /></div>
          <div class="steps-card steps-card--3"><img class="steps-img" src="/steps.png" alt="" /></div>
          <div class="steps-card steps-card--4"><img class="steps-img" src="/steps.png" alt="" /></div>
        </div>
      </div>

      <div class="content">
        <div class="logo-wrap">
          <img
            class="logo"
            src={nexusLogo.src}
            alt="Horizons Nexus"
            width="681"
            height="308"
          />
        </div>

        <div class="card-wrap">
          <div class="card">
            <div class="card-flip">
              <div class="card-face card-face--front">
                <Image
                  class="card-art"
                  src={cardBorder}
                  alt=""
                  widths={[400, 525, 1050]}
                  sizes="(max-width: 600px) 92vw, 525px"
                  loading="eager"
                />
                <div class="card-body card-body--orig">
                  <h2 class="card-title">play the hand you&rsquo;re dealt</h2>
                  <p class="card-desc">
                    We&rsquo;re running a hackathon where you draw cards to build wild and crazy projects.
                    <span class="card-desc__sub">San Francisco, June 19th &ndash; 21st</span>
                  </p>
                  <form
                    class="card-form"
                    action="https://horizons.hackclub.com"
                    method="get"
                    target="_blank"
                  >
                    <input
                      type="email"
                      name="email"
                      class="card-input"
                      placeholder="me@gmail.com"
                      aria-label="Email address"
                      autocomplete="email"
                    />
                    <button type="submit" class="card-button">Sign Up &rarr;</button>
                  </form>
                  <p class="card-scroll">SCROLL TO READ MORE...</p>
                </div>
                <div class="card-body card-body--alt" aria-hidden="true">
                  <p class="card-alt-text">
                    This summer,<br />we&rsquo;re running a different kind of hackathon&hellip;
                  </p>
                </div>
              </div>
              <div class="card-face card-face--back" aria-hidden="true">
                <Image
                  class="card-art card-art--back"
                  src={cardBorderBack}
                  alt=""
                  widths={[400, 525, 1050]}
                  sizes="(max-width: 600px) 92vw, 525px"
                  loading="eager"
                />
                <p class="card-invited-text">And you&rsquo;re invited.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <section class="info" aria-labelledby="info-title" style={`--info-bg: ${infoBg}; --faq-bg: ${faqBg};`}>
    <h2 id="info-title" class="sr-only">About Nexus</h2>
    <Image
      class="info__strip"
      src={infoStrip}
      alt=""
      widths={[800, 1403, 2200]}
      sizes="100vw"
      loading="lazy"
    />

    <div class="info__rows">
      <div class="info-row info-row--text-left">
        <article class="info-card">
          <h3 class="info-card__title info-card__title--unicase">What&rsquo;s a hackathon?</h3>
          <p class="info-card__body">
            A social coding marathon! Imagine a weekend where teenagers come together to code projects for fun&mdash;however goofy or janky&mdash;and share them with each other.
          </p>
          <p class="info-card__body">
            You&rsquo;ll have a goal to work towards, side quests to tackle, and new friends to hang out with. You don&rsquo;t need coding experience&mdash;just an open mind.
          </p>
        </article>
        <Image
          class="info-photo"
          src={infoPhoto}
          alt="A teenager at a hackathon, soldering an electronics project on a desk."
          widths={[400, 545, 1090]}
          sizes="(max-width: 800px) 88vw, 545px"
          loading="lazy"
        />
      </div>

      <div class="info-row info-row--text-right">
        <Image
          class="info-photo"
          src={infoPhoto}
          alt="A teenager building a hardware project at a Hack Club hackathon."
          widths={[400, 545, 1090]}
          sizes="(max-width: 800px) 88vw, 545px"
          loading="lazy"
        />
        <article class="info-card">
          <h3 class="info-card__title info-card__title--unicase">Make new friends</h3>
          <p class="info-card__body">
            Hackathons aren&rsquo;t just time to code! At Nexus, you&rsquo;ll meet fun teenagers who love making as much as you do.
          </p>
          <p class="info-card__body">
            From board games to karaoke nights, Nexus is one long social and a chance to befriend people you adore.
          </p>
        </article>
      </div>

      <div class="info-row info-row--text-left">
        <article class="info-card">
          <h3 class="info-card__title info-card__title--unicase">Build what you love</h3>
          <p class="info-card__body">
            At Nexus, don&rsquo;t worry about being realistic. Build the projects that&rsquo;d never make sense IRL, but would be perfect for tackling the zombies&mdash;from post-apocalyptic food delivery to zombie-sized mousetraps.
          </p>
          <p class="info-card__body">
            Worried about how you&rsquo;ll do it all? Fear not; you can always receive 1:1 help from experienced mentors.
          </p>
        </article>
        <Image
          class="info-photo"
          src={infoPhoto}
          alt="A teenager working on a creative hardware build during a hackathon."
          widths={[400, 545, 1090]}
          sizes="(max-width: 800px) 88vw, 545px"
          loading="lazy"
        />
      </div>
    </div>

    <div class="faq">
      <h2 class="faq__title">FAQ</h2>
      <div class="faq__grid">
        <article class="info-card faq__card">
          <h3 class="info-card__title">Eligibility</h3>
          <p class="info-card__body">
            Anyone 13&ndash;18 is welcome! If you&rsquo;re in middle school or a gap year student, check in with us at <a class="info-link" href="mailto:apocalypse@hackclub.com">apocalypse@hackclub.com</a>. Don&rsquo;t forget to bring an ID that includes a photo! Read our policy <a class="info-link" href="https://apocalypse.hackclub.com/id" target="_blank" rel="noopener">here</a>.
          </p>
        </article>
        <article class="info-card faq__card">
          <h3 class="info-card__title">Is this free?</h3>
          <p class="info-card__body">
            Yep. Attending costs a grand total of $0. Zilch. Nada. Nothing. From meals to mini-events, Nexus is universally accessible.
          </p>
        </article>
      </div>
    </div>
  </section>
</Base>

<style>
  .scroll-shell {
    position: relative;
    width: 100%;
    height: 900svh;
  }

  .hero {
    position: sticky;
    top: 0;
    width: 100%;
    height: 100svh;
    overflow: hidden;
    background: #000;
    --card-w: clamp(280px, 32vw, 640px);
    --card-peek: 0.659;
    --top-pad: clamp(20px, 19svh, 180px);
    --logo-gap: 22px;
    --logo-max-h: max(80px, calc(100svh - var(--top-pad) - (1.4 - var(--card-peek)) * var(--card-w) - var(--logo-gap)));
    --card-translate-up: calc(-50svh + (0.7 - var(--card-peek)) * var(--card-w));
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes card-entry-slide {
    from { transform: translateX(-50%) translateY(100%); }
    to { transform: translateX(-50%) translateY(0); }
  }

  .bg__blob,
  .logo-wrap,
  .bg__doodles,
  .bg__strand,
  .card-wrap {
    animation-fill-mode: backwards;
    animation-timing-function: ease-out;
  }

  .bg__blob {
    animation-name: fade-in;
    animation-duration: 1100ms;
    animation-delay: 200ms;
  }

  .logo-wrap,
  .bg__doodles {
    animation-name: fade-in;
    animation-duration: 1000ms;
    animation-delay: 1100ms;
  }

  .bg__strand {
    animation-name: fade-in;
    animation-duration: 1000ms;
    animation-delay: 1900ms;
  }

  .card-wrap {
    animation-name: card-entry-slide;
    animation-duration: 1200ms;
    animation-delay: 2700ms;
    animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    .bg__blob,
    .logo-wrap,
    .bg__doodles,
    .bg__strand,
    .card-wrap {
      animation: none;
    }
  }

  .bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .bg :global(img) {
    pointer-events: none;
    user-select: none;
  }

  .bg__base {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .bg__doodles {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    opacity: calc(1 - var(--reveal, 0));
  }

  .bg__strand {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    height: max(110svh, clamp(720px, 70.2vw, 1400px));
    width: auto;
    max-width: 45%;
    display: block;
    object-fit: cover;
    object-position: center;
    opacity: calc(1 - var(--reveal, 0));
  }

  .bg__strand--left {
    left: 0;
  }

  .bg__strand--right {
    right: 0;
  }

  .bg__blob {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(360px, 53.32vw, 1100px);
    aspect-ratio: 1;
    overflow: hidden;
    pointer-events: none;
    opacity: calc(1 - var(--reveal, 0));
  }

  .stage4 {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
  }

  .stage4 :global(.stage4-bg) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    opacity: var(--reveal, 0);
  }

  .stage4-frame {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(100vw, calc(100svh * 1403 / 942));
    aspect-ratio: 1403 / 942;
    pointer-events: none;
    user-select: none;
  }

  /* Bord state ("Here's how it works") - centered, scaled larger than Figma's 591x452 */
  .bord-frame {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 58%;
    aspect-ratio: 591 / 452;
    pointer-events: none;
  }

  .bord-slice {
    position: absolute;
    pointer-events: none;
  }

  .bord-slice :global(img) {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: fill;
  }

  .bord-slice--tl     { top: 0;     left: 0;     width: 10.20%; height: 14.00%; }
  .bord-slice--top    { top: 0;     left: 10.20%; right: 10.20%; height: 14.00%; }
  .bord-slice--tr     { top: 0;     right: 0;    width: 10.20%; height: 14.00%; }
  .bord-slice--left   { top: 14.00%; bottom: 12.70%; left: 0;    width: 10.20%; }
  .bord-slice--center { top: 14.00%; left: 10.20%; right: 10.20%; bottom: 12.70%; }
  .bord-slice--right  { top: 14.00%; bottom: 12.70%; right: 0;   width: 10.20%; }
  .bord-slice--bl     { bottom: 0;  left: 0;     width: 10.20%; height: 12.70%; }
  .bord-slice--bottom { bottom: 0;  left: 10.20%; right: 10.20%; height: 12.70%; }
  .bord-slice--br     { bottom: 0;  right: 0;    width: 10.20%; height: 12.70%; }

  /* Staggered bord slice fade-in via --reveal; fade out via --phase4 */
  .bord-slice--tl     { opacity: calc(clamp(0, calc((var(--reveal, 0) - 0.00) * 5), 1) * (1 - var(--bord-out, 0))); }
  .bord-slice--top    { opacity: calc(clamp(0, calc((var(--reveal, 0) - 0.10) * 5), 1) * (1 - var(--bord-out, 0))); }
  .bord-slice--tr     { opacity: calc(clamp(0, calc((var(--reveal, 0) - 0.20) * 5), 1) * (1 - var(--bord-out, 0))); }
  .bord-slice--right  { opacity: calc(clamp(0, calc((var(--reveal, 0) - 0.30) * 5), 1) * (1 - var(--bord-out, 0))); }
  .bord-slice--br     { opacity: calc(clamp(0, calc((var(--reveal, 0) - 0.40) * 5), 1) * (1 - var(--bord-out, 0))); }
  .bord-slice--bottom { opacity: calc(clamp(0, calc((var(--reveal, 0) - 0.50) * 5), 1) * (1 - var(--bord-out, 0))); }
  .bord-slice--bl     { opacity: calc(clamp(0, calc((var(--reveal, 0) - 0.60) * 5), 1) * (1 - var(--bord-out, 0))); }
  .bord-slice--left   { opacity: calc(clamp(0, calc((var(--reveal, 0) - 0.70) * 5), 1) * (1 - var(--bord-out, 0))); }
  .bord-slice--center { opacity: calc(clamp(0, calc((var(--reveal, 0) - 0.80) * 5), 1) * (1 - var(--bord-out, 0))); }

  .bord-text {
    position: absolute;
    left: 50%;
    top: 43.4%;
    transform: translateX(-50%);
    margin: 0;
    font-family: 'Delius', system-ui, sans-serif;
    font-weight: 400;
    font-size: clamp(20px, 3.42vw, 56px);
    text-align: center;
    color: #fff;
    white-space: nowrap;
    line-height: 1;
    opacity: calc(clamp(0, calc((var(--reveal, 0) - 0.6) * 3), 1) * (1 - var(--bord-out, 0)));
  }

  /* 4-card grid (state 5), fades in during phase4 */
  .steps-card {
    position: absolute;
    width: 26.24%; /* 368.173 / 1403 */
    aspect-ratio: 368.173 / 270.438;
    overflow: hidden;
    pointer-events: none;
  }

  .steps-card--1 { left: 23.09%; top: 9.34%; }
  .steps-card--2 { left: 50.54%; top: 28.36%; }
  .steps-card--3 { left: 23.09%; top: 42.72%; }
  .steps-card--4 { left: 50.54%; top: 61.84%; }

  .steps-img {
    position: absolute;
    width: 291.26%;
    height: 297.24%;
    max-width: none;
    display: block;
    user-select: none;
    pointer-events: none;
  }

  .steps-card--1 .steps-img { left: -40.62%;  top: -8.56%;   }
  .steps-card--2 .steps-img { left: -150.14%; top: -61.86%;  }
  .steps-card--3 .steps-img { left: -41.61%;  top: -130%;    }
  .steps-card--4 .steps-img { left: -149.15%; top: -177.91%; }

  /* Each step fades + scales 1.2 → 1; per-step progress provided by JS */
  .steps-card--1 {
    opacity: var(--step-1, 0);
    transform: scale(calc(1.2 - 0.2 * var(--step-1, 0)));
  }
  .steps-card--2 {
    opacity: var(--step-2, 0);
    transform: scale(calc(1.2 - 0.2 * var(--step-2, 0)));
  }
  .steps-card--3 {
    opacity: var(--step-3, 0);
    transform: scale(calc(1.2 - 0.2 * var(--step-3, 0)));
  }
  .steps-card--4 {
    opacity: var(--step-4, 0);
    transform: scale(calc(1.2 - 0.2 * var(--step-4, 0)));
  }

  .bg__blob :global(.bg__blob-img) {
    position: absolute;
    display: block;
    width: 254.38%;
    height: 190.79%;
    left: -82.06%;
    top: -46.5%;
    max-width: none;
  }

  .content {
    position: relative;
    z-index: 1;
    min-height: 100svh;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: var(--top-pad) 16px 0;
  }

  .logo-wrap {
    flex-shrink: 0;
    display: block;
  }

  .logo {
    width: min(clamp(320px, 55vw, 1050px), calc(var(--logo-max-h) * 681 / 308));
    height: auto;
    aspect-ratio: 681 / 308;
    display: block;
    user-select: none;
    pointer-events: none;
    opacity: calc(1 - var(--phase1, 0));
  }

  .card-wrap {
    position: absolute;
    bottom: calc(-1 * var(--card-peek) * var(--card-w));
    left: 50%;
    width: var(--card-w);
    aspect-ratio: 525 / 735;
    transform: translateX(-50%);
    perspective: 1800px;
  }

  .card {
    position: relative;
    width: 100%;
    height: 100%;
    container-type: inline-size;
    color: #fff;
    transform: translateY(calc(var(--card-translate-up) * var(--phase1, 0)))
               rotate(calc(var(--card-rot, -2.41) * 1deg))
               rotateX(calc(var(--hover-y, 0) * -6deg))
               rotateY(calc(var(--hover-x, 0) * 6deg))
               scale(calc(1 + 4 * var(--zoom, 0)));
    transform-origin: center center;
    perspective: 1800px;
  }

  .card-flip {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    transform: rotateY(calc(var(--flip-rot, 0) * 180deg + var(--zoom-rot, 0) * 180deg));
    transition: transform 0s;
  }

  .card-face {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    overflow: hidden;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .card-face--front {
    background: #000;
    outline: 2px solid rgba(255, 255, 255, var(--phase1, 0));
    outline-offset: -2px;
  }

  .card-face--back {
    transform: rotateY(180deg);
    background: #fff;
    outline: 2px solid #000;
    outline-offset: -2px;
    color: #000;
  }

  .card-invited-text {
    position: absolute;
    top: 46.667%;
    left: 50%;
    transform: translateX(-50%);
    width: 80.76cqi;
    margin: 0;
    font-family: 'Delius', system-ui, sans-serif;
    font-weight: 400;
    font-size: 6.857cqi;
    text-align: center;
    line-height: normal;
    color: #000;
  }

  .card-art {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    pointer-events: none;
    user-select: none;
  }

  .card-body {
    position: absolute;
    inset: 0;
  }

  .card-body--orig {
    opacity: calc(1 - var(--phase1, 0));
  }

  .card-body--alt {
    /* Visible after the card lifts, faded out by flip 1 and kept hidden
       through the back-face hold and the back→front flip. */
    opacity: calc(var(--phase1, 0) * (1 - var(--flip-rot, 0)));
    pointer-events: none;
  }

  .card-title {
    position: absolute;
    top: 13.726%;
