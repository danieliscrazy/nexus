</style>

<script>
  const root = document.documentElement;
  const shell = document.querySelector('.scroll-shell');
  let raf: number | null = null;

  const clamp01 = (v: number) => Math.max(0, Math.min(1, v));
  // Smoothstep: 0 velocity at endpoints, so chained transitions hand off without snap.
  const ease = (t: number) => t * t * (3 - 2 * t);

  const update = () => {
    if (!(shell instanceof HTMLElement)) return;
    const rect = shell.getBoundingClientRect();
    const range = shell.offsetHeight - window.innerHeight;
    if (range <= 0) {
      root.style.setProperty('--scroll-progress', '0');
      root.style.setProperty('--phase1', '0');
      root.style.setProperty('--phase2', '0');
      root.style.setProperty('--steps-out', '0');
      root.style.setProperty('--cta-in', '0');
      root.style.setProperty('--cta-events', 'none');
      return;
    }
    const scrolled = Math.max(0, Math.min(range, -rect.top));
    const progress = scrolled / range;
    // The hero choreography (logo, card flips, zoom, bord, steps) was tuned
    // against an original 900svh scroll range. To preserve those exact physical
    // scroll distances while still being able to grow the shell freely for new
    // phases at the end, drive the old animation off `oldProgress` — scroll
    // distance in svh units, capped at the original 900svh range — instead of
    // the live `progress` fraction.
    const vh = window.innerHeight;
    const scrolledSvh = scrolled / vh;
    const oldProgress = Math.min(scrolledSvh / 9, 1);
    const p = Math.min(oldProgress / 0.80, 1);
    // 4 transitions of 20% each separated by 4% holds.
    const phase1 = clamp01(p / 0.2);
    const phase2 = clamp01((p - 0.24) / 0.2);
    const phase3 = clamp01((p - 0.48) / 0.2);
    const phase4 = clamp01((p - 0.72) / 0.28);
    const tilt = clamp01(phase2 / 0.6);
    // Choreography: 1) "this summer" front showing, 2) flip to back,
    // 3) hold on "and you're invited" so it can be read, 4) flip back to front,
    // 5) midway through that flip (rotateY≈270°, black side visible again) the
    // zoom kicks in. Reveal starts as the zoom is finishing up.
    const flip = clamp01((p - 0.30) / 0.10);     // front → back
    const flipBack = clamp01((p - 0.50) / 0.10); // back → front
    const zoom = clamp01((p - 0.55) / 0.12);     // starts mid-flipBack
    const reveal = clamp01((p - 0.62) / 0.10);
    const bordOut = clamp01(phase4 / 0.36);
    // Steps span oldProgress 0.63 → 0.92 (≈290svh of scroll within the 900svh
    // legacy range).
    const stepsIn = clamp01((oldProgress - 0.63) / 0.29);
    // Each step fades over 0.10 of stepsIn with a 0.20 hold before the next.
    const step1 = clamp01(stepsIn / 0.10);
    const step2 = clamp01((stepsIn - 0.30) / 0.10);
    const step3 = clamp01((stepsIn - 0.60) / 0.10);
    const step4 = clamp01((stepsIn - 0.90) / 0.10);
    // Cta phase: sequential.
    //   1) Hold all four steps visible after the last one fades in.
    //   2) Fade the entire steps grid out together.
    //   3) Fade the "How Can I Go?" card in (starts the instant steps-out ends).
    //   4) Tail hold so the cta is fully readable at the bottom of the shell.
    // Values are in svh units (1.0 = one viewport of scroll). Anchored to
    // absolute scroll position so growing the shell only extends the tail hold.
    // The last step finishes appearing around scrolledSvh = 8.28.
    const STEPS_OUT_START = 10.2; // ~192svh of all-steps-visible hold
    const STEPS_OUT_END   = 11.7; // 150svh fade duration
    const CTA_IN_START    = STEPS_OUT_END - 0.4; // overlap the tail of steps-out
    const CTA_IN_END      = 13.1; // 180svh cta fade-in
    const stepsOut = clamp01(
      (scrolledSvh - STEPS_OUT_START) / (STEPS_OUT_END - STEPS_OUT_START)
    );
    const ctaIn = clamp01(
      (scrolledSvh - CTA_IN_START) / (CTA_IN_END - CTA_IN_START)
    );
    root.style.setProperty('--steps-out', stepsOut.toFixed(4));
    root.style.setProperty('--cta-in', ctaIn.toFixed(4));
    // Only enable clicks once the button is mostly visible — opacity:0 elements
    // are still clickable by default.
    root.style.setProperty('--cta-events', ctaIn > 0.6 ? 'auto' : 'none');
    root.style.setProperty('--scroll-progress', progress.toFixed(4));
    root.style.setProperty('--phase1', phase1.toFixed(4));
    root.style.setProperty('--phase2', phase2.toFixed(4));
    root.style.setProperty('--phase3', phase3.toFixed(4));
    root.style.setProperty('--phase4', phase4.toFixed(4));
    root.style.setProperty('--tilt', tilt.toFixed(4));
    root.style.setProperty('--flip', flip.toFixed(4));
    root.style.setProperty('--zoom', zoom.toFixed(4));
    root.style.setProperty('--reveal', reveal.toFixed(4));
    root.style.setProperty('--bord-out', bordOut.toFixed(4));
    root.style.setProperty('--steps-in', stepsIn.toFixed(4));
    root.style.setProperty('--step-1', step1.toFixed(4));
    root.style.setProperty('--step-2', step2.toFixed(4));
    root.style.setProperty('--step-3', step3.toFixed(4));
    root.style.setProperty('--step-4', step4.toFixed(4));
    // Card rotation: three overlapping eased ramps. While one is decelerating,
    // the next is already accelerating, so total velocity stays non-zero from
    // start to end — no parking at any beat.
    // rotA/rotB do most of the work before the final flip (≈progress 0.50);
    // rotB's smoothstep tail decelerates into the flip so the card eases off
    // rather than carrying high angular velocity through it. rotC adds a small
    // tail through the zoom and settles by 0.80 (start of the steps section),
    // since the card isn't the focus once steps take over.
    const rotA = ease(clamp01(p / 0.30));
    const rotB = ease(clamp01((p - 0.15) / 0.50));
    const rotC = ease(clamp01((p - 0.30) / 0.60));
    const cardRot = -2.41 + 4 * rotA + 10 * rotB + 6.41 * rotC;
    root.style.setProperty('--card-rot', cardRot.toFixed(4));
    // Flip drivers. --flip-rot is the first (front→back) flip; --zoom-rot
    // (legacy name) is the second (back→front) flip that runs after the hold.
    root.style.setProperty('--flip-rot', ease(flip).toFixed(4));
    root.style.setProperty('--zoom-rot', ease(flipBack).toFixed(4));
  };

  window.addEventListener(
    'scroll',
    () => {
      if (raf !== null) return;
      raf = requestAnimationFrame(() => {
        update();
        raf = null;
      });
    },
    { passive: true }
  );

  window.addEventListener('resize', update);
  update();

  // Subtle 3D hover tilt: cursor coords normalized relative to the card's own
  // bounding rect, so ±1 ≈ one card half-dimension from center. Lerped per
  // frame to glide instead of snapping.
  if (window.matchMedia('(hover: hover)').matches) {
    const card = document.querySelector('.card');
    let targetX = 0;
    let targetY = 0;
    let smoothX = 0;
    let smoothY = 0;
    let hoverRaf: number | null = null;
    const LERP = 0.1;

    const tickHover = () => {
      smoothX += (targetX - smoothX) * LERP;
      smoothY += (targetY - smoothY) * LERP;
      root.style.setProperty('--hover-x', smoothX.toFixed(4));
      root.style.setProperty('--hover-y', smoothY.toFixed(4));
      if (Math.abs(targetX - smoothX) > 0.001 || Math.abs(targetY - smoothY) > 0.001) {
        hoverRaf = requestAnimationFrame(tickHover);
      } else {
        hoverRaf = null;
      }
    };

    window.addEventListener(
      'mousemove',
      (e) => {
        if (!(card instanceof HTMLElement)) return;
        const rect = card.getBoundingClientRect();
        const inside =
          e.clientX >= rect.left &&
          e.clientX <= rect.right &&
          e.clientY >= rect.top &&
          e.clientY <= rect.bottom;
        if (inside) {
          const cx = rect.left + rect.width / 2;
          const cy = rect.top + rect.height / 2;
          targetX = (e.clientX - cx) / (rect.width / 2);
          targetY = (e.clientY - cy) / (rect.height / 2);
        } else {
          // Cursor left the card — ease back to flat.
          targetX = 0;
          targetY = 0;
        }
        if (hoverRaf === null) hoverRaf = requestAnimationFrame(tickHover);
      },
      { passive: true }
    );
  }
</script>
